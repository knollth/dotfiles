;;; setup-typst.el --- Typst-specific configuration

(use-package typst-ts-mode
  :vc (:url "https://codeberg.org/meow_king/typst-ts-mode.git")
  :mode "\\.typ\\'"
  :hook (typst-ts-mode . eglot-ensure) ;; The language mode pulls in the LSP
  :config
  ;; Register Tinymist with Eglot only when Eglot loads
  (with-eval-after-load 'eglot
    (add-to-list 'eglot-server-programs
                 `(typst-ts-mode . ("tinymist" "lsp")))))

(provide 'setup-typst)
