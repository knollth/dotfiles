(defun my/meow-setup ()
    ;; Motion State – nur Bewegung
    (meow-motion-overwrite-define-key
     '("h" . meow-left)
     '("j" . meow-next)
     '("k" . meow-prev)
     '("l" . meow-right)
     '("<escape>" . ignore))

    ;; Normal State
    (meow-normal-define-key
     ;; expand (Auswahl)
     '("0" . meow-expand-0)
     '("1" . meow-expand-1)
     '("2" . meow-expand-2)
     '("3" . meow-expand-3)
     '("4" . meow-expand-4)
     '("5" . meow-expand-5)
     '("6" . meow-expand-6)
     '("7" . meow-expand-7)
     '("8" . meow-expand-8)
     '("9" . meow-expand-9)

     ;; Bewegung
     '("h" . meow-left)
     '("j" . meow-next)
     '("k" . meow-prev)
     '("l" . meow-right)

     ;; Edit
     '("i" . meow-insert)
     '("a" . meow-append)
     '("o" . meow-open-below)
     '("O" . meow-open-above)
     '("u" . meow-undo)

     ;; Auswahl
     '("w" . meow-mark-word)
     '("e" . meow-mark-symbol)
     '("b" . meow-mark-line)
     '("B" . meow-mark-block)

     ;; Yank / Kill
     '("y" . meow-yank)
     '("d" . meow-delete)
     '("c" . meow-change)

     ;; Search
     '("/" . meow-search)
     '("n" . meow-search-next)
     '("N" . meow-search-prev)

     ;; Escape
     '("<escape>" . meow-cancel-selection)))

(use-package meow
  :init
  (meow-global-mode 1)
  :config
  (setq meow-cheatsheet-layout meow-cheatsheet-layout-qwerty)
  (my/meow-setup))
