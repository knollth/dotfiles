#!/bin/bash
set -e

ZIG_DIR="$HOME/.local/zig"
ZLS_DIR="$HOME/.local/src/zls"
BIN_DIR="$HOME/.local/bin"

mkdir -p "$BIN_DIR" "$HOME/.local/src"

echo "==> Fetching latest Zig master..."
ZIG_INDEX=$(curl -s https://ziglang.org/download/index.json)
ZIG_URL=$(echo "$ZIG_INDEX" | jq -r '.master."x86_64-linux".tarball')
ZIG_VERSION=$(echo "$ZIG_INDEX" | jq -r '.master.version')

echo "    Version: $ZIG_VERSION"

# Download & install Zig
rm -rf "$ZIG_DIR"
mkdir -p "$ZIG_DIR"
curl -L "$ZIG_URL" | tar xJ --strip-components=1 -C "$ZIG_DIR"

# Symlink
ln -sf "$ZIG_DIR/zig" "$BIN_DIR/zig"

echo "==> Zig installed: $(zig version)"

# Clone or update ZLS
echo "==> Updating ZLS..."
if [ -d "$ZLS_DIR" ]; then
    cd "$ZLS_DIR"
    git fetch --all
    git reset --hard origin/master
else
    git clone https://github.com/zigtools/zls "$ZLS_DIR"
    cd "$ZLS_DIR"
fi

# Build ZLS with new Zig
echo "==> Building ZLS..."
"$BIN_DIR/zig" build -Doptimize=ReleaseSafe

# Install
cp zig-out/bin/zls "$BIN_DIR/"

echo "==> Done!"
echo "    Zig: $(zig version)"
echo "    ZLS: $(zls --version)"
